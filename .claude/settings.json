{
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "fileCheckpointingEnabled": true,
  "autoCompactEnabled": true,
  "showTurnDuration": true,
  "tui": "fullscreen",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc --noEmit",
            "shell": "powershell",
            "async": true,
            "statusMessage": "Type-checking..."
          }
        ]
      }
    ]
  }
}
